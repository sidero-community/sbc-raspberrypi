 drivers/mfd/Makefile          |   1 +
 drivers/mfd/rp1.c             | 188 +++++++++++++++++++++++++++
 include/dt-bindings/mfd/rp1.h | 235 ++++++++++++++++++++++++++++++++++
 4 files changed, 434 insertions(+)
 create mode 100644 drivers/mfd/rp1.c
 create mode 100644 include/dt-bindings/mfd/rp1.h

